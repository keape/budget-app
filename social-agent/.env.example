# OpenRouter API (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Modello da usare — default è Claude Sonnet. Altri: google/gemini-pro, openai/gpt-4o
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# X / Twitter API v2 — OAuth 1.0a User Context
# Create app at: https://developer.twitter.com/en/apps
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Facebook Graph API v19
# 1. Create a Facebook Page for Budget365
# 2. Create a Facebook Group and add the Page as admin
# 3. Get a Page Access Token via Graph API Explorer (valid 60 days)
#    https://developers.facebook.com/tools/explorer/
# 4. Set the Group ID (from the group URL or Graph API)
FACEBOOK_PAGE_TOKEN=
FACEBOOK_GROUP_ID=

# ntfy.sh push notifications
# 1. Install ntfy app on your phone (iOS/Android — free)
# 2. Subscribe to your topic in the app
# 3. Set any unique string as your topic (keep it private)
NTFY_TOPIC=budget365-keape

# Optional: override the app API base URL for user count fetching
API_BASE_URL=https://budget-app-ios-backend.onrender.com
